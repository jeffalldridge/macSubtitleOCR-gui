root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false  # markdown line breaks need trailing spaces

[Makefile]
indent_style = tab

[*.{yml,yaml,json}]
indent_size = 2

[*.swift]
indent_size = 4
